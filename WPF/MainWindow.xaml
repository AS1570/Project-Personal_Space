<Window x:Class="WpfApp3.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp3"
        mc:Ignorable="d"
        Title="Personal Zone" Height="450" Width="800"
        MinHeight="450" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" ResizeMode="CanResizeWithGrip"
        Background="{DynamicResource DesktopBg}">
    <Grid x:Name="RootLayout">

        <ContentControl x:Name="MainContent"
                        Margin="0,35,0,0"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        AllowDrop="True"/>

        <Border x:Name="TopBarBorder"
                Background="{DynamicResource DesktopBg}"
                Height="35"
                VerticalAlignment="Top"
                HorizontalAlignment="Stretch"
                ClipToBounds="True"
                MouseLeftButtonDown="OnTopBarMouseLeftButtonDown">
            <Grid>
                <StackPanel x:Name="TopBarLeftPanel"
                            Orientation="Horizontal"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Margin="0,0,0,0">
                    <Button x:Name="BtnTopBarLock"
                            Width="35" Height="35"
                            Background="Transparent"
                            Foreground="{DynamicResource TextPrimary}"
                            BorderThickness="0"
                            FontSize="14"
                            Cursor="Hand"
                            Content="🔒"
                            ToolTip="锁定"
                            Visibility="Collapsed"
                            Click="OnTopBarLockClick">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd"
                                        Background="{TemplateBinding Background}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="{DynamicResource GlassWhite}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <TextBlock x:Name="TxtTopBarTime"
                               Text="00:00"
                               Foreground="{DynamicResource TextPrimary}"
                               FontSize="14"
                               VerticalAlignment="Center"
                               Margin="10,0,0,0"/>
                    <TextBlock x:Name="TxtTopBarDateSep"
                               Text="  "
                               Foreground="{DynamicResource TextPrimary}"
                               FontSize="14"
                               VerticalAlignment="Center" />
                    <TextBlock x:Name="TxtTopBarDate"
                               Text="2026/06/15"
                               Foreground="{DynamicResource TextSecondary}"
                               FontSize="14"
                               VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel x:Name="TopBarRightPanel"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button x:Name="BtnMinimize"
                            Width="48" Height="35"
                            Background="Transparent"
                            Foreground="{DynamicResource TextPrimary}"
                            BorderThickness="0"
                            FontSize="15"
                            Cursor="Hand"
                            Click="OnMinimizeClick">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd"
                                        Background="{TemplateBinding Background}"
                                        Width="48" Height="35">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="{DynamicResource GlassWhite}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <TextBlock Text="─" FontWeight="Bold" FontSize="13"/>
                    </Button>

                    <Button x:Name="BtnMaxRestore"
                            Width="48" Height="35"
                            Background="Transparent"
                            Foreground="{DynamicResource TextPrimary}"
                            BorderThickness="0"
                            FontSize="15"
                            Cursor="Hand"
                            Click="OnMaxRestoreClick">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd"
                                        Background="{TemplateBinding Background}"
                                        Width="48" Height="35">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="{DynamicResource GlassWhite}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <TextBlock x:Name="TxtMaxRestoreIcon" Text="▢" FontSize="15"/>
                    </Button>

                    <Button x:Name="BtnClose"
                            Width="48" Height="35"
                            Background="Transparent"
                            Foreground="{DynamicResource TextPrimary}"
                            BorderThickness="0"
                            FontSize="13"
                            Cursor="Hand"
                            Click="OnCloseClick">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd"
                                        Background="{TemplateBinding Background}"
                                        Width="48" Height="35">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="{DynamicResource CloseHover}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <TextBlock Text="✕" FontSize="13"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Border x:Name="FullscreenOverlay"
                Background="{DynamicResource ShadowColor}"
                Visibility="Collapsed">
            <ContentControl x:Name="FullscreenHost"/>
        </Border>

    </Grid>
</Window>
