<UserControl x:Class="WpfApp3.UserControl0"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WpfApp3"
             mc:Ignorable="d"
             d:DesignHeight="1080" d:DesignWidth="1920"
             MouseDown="OnLockScreenMouseDown">
    <Grid x:Name="RootGrid" Background="{DynamicResource DesktopBg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel x:Name="TimeDatePanel"
                    Grid.Row="0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom">
            <Label x:Name="TimeLabel"
                   Content="00:00:00"
                   FontSize="90" FontWeight="Bold"
                   Foreground="{DynamicResource White}"
                   HorizontalAlignment="Center" />
            <Label x:Name="DateLabel"
                   Content="----年--月--日 星期-"
                   FontSize="25"
                   Foreground="{DynamicResource CcWhite}"
                   HorizontalAlignment="Center" />
        </StackPanel>

        <StackPanel x:Name="LoginPanel"
                    Grid.RowSpan="2"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="500"
                    Visibility="Collapsed">

            <Label x:Name="StatusLabel"
                   Content="输入密码"
                   FontSize="20"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,15"
                   Foreground="{DynamicResource TextPrimary}" />

            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" MinWidth="42"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto" MinWidth="42"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="BtnReturn"
                        Grid.Column="0"
                        Width="42" Height="42"
                        Background="{DynamicResource BorderColor}"
                        Foreground="{DynamicResource White}"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource AccentBorder}"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8"
                                    Width="42" Height="42">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{DynamicResource AccentBorder}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{DynamicResource AccentBorderAlt}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <TextBlock Text="🔙" FontSize="18" TextAlignment="Center"/>
                </Button>

                <PasswordBox x:Name="PasswordBox"
                             Grid.Column="1"
                             FontSize="18"
                             Height="44"
                             Margin="12,0"
                             HorizontalContentAlignment="Center"
                             VerticalContentAlignment="Center" />

                <Button x:Name="BtnLogin"
                        Grid.Column="2"
                        Width="42" Height="42"
                        Background="{DynamicResource Accent}"
                        Foreground="{DynamicResource White}"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource AccentLight}"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8"
                                    Width="42" Height="42">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{DynamicResource AccentLight}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{DynamicResource AccentDark}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <TextBlock Text="🔐" FontSize="18" TextAlignment="Center"/>
                </Button>
            </Grid>

            <Label x:Name="HintLabel"
                   Content="初始密码：admin123"
                   FontSize="14"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,0"
                   Foreground="{DynamicResource CcGray}"
                   Visibility="Collapsed" />
        </StackPanel>
    </Grid>
</UserControl>
