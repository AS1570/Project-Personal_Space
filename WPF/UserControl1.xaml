<UserControl x:Class="WpfApp3.UserControl1"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WpfApp3"
             xmlns:local2="clr-namespace:WpfApp3.Widgets"
             mc:Ignorable="d"
             d:DesignHeight="1080" d:DesignWidth="1920"
             Focusable="True">
    <UserControl.Resources>
        <Style x:Key="SquareTaskbarButton" TargetType="Button">
            <Setter Property="Width" Value="42"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource White}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource GlassWhite}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource GlassWhiteBold}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RectTaskbarButton" TargetType="Button">
            <Setter Property="MinWidth" Value="80"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource White}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource GlassWhite}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource GlassWhiteBold}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid x:Name="RootGridUC1">
        <MediaElement x:Name="DesktopVideoWallpaper"
                      Panel.ZIndex="-1"
                      LoadedBehavior="Manual"
                      UnloadedBehavior="Stop"
                      Stretch="UniformToFill"
                      Volume="0"
                      Visibility="Collapsed"/>
        <Border x:Name="BottomBarFullBg"
                VerticalAlignment="Bottom"
                Height="70"
                Background="{DynamicResource DesktopBg}"/>
        <Grid x:Name="DesktopGrid">
            <Canvas x:Name="GridLinesCanvas" Background="Transparent" IsHitTestVisible="False"/>
            <Canvas x:Name="WidgetCanvas" Background="Transparent"/>
            <ContentControl x:Name="DesktopContent" Panel.ZIndex="1"/>
        </Grid>

        <Popup x:Name="MiniPlayerPopup"
               PlacementTarget="{x:Reference Button8}"
               Placement="Top"
               HorizontalOffset="0"
               VerticalOffset="-8"
               StaysOpen="False"
               AllowsTransparency="True">
            <Border Background="Transparent" ClipToBounds="True" CornerRadius="14">
                <Border Background="{DynamicResource BgPanel}"
                        CornerRadius="14"
                        Padding="18,14"
                        MinWidth="340"
                        BorderBrush="{DynamicResource BorderColor}"
                        BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" BlurRadius="20" ShadowDepth="4" Opacity="0.5"/>
                    </Border.Effect>
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="PopupBtnClose"
                                Grid.Column="0"
                                Width="28" Height="28"
                                Background="Transparent"
                                Foreground="{DynamicResource TextSecondary}"
                                BorderThickness="0"
                                Cursor="Hand"
                                FontSize="16"
                                Content="✕"
                                ToolTip="关闭当前音乐"
                                VerticalAlignment="Center"
                                Margin="0,0,8,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="{DynamicResource GlassWhite}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Grid Grid.Column="1" ClipToBounds="True" Margin="8,0">
                            <Canvas x:Name="PopupScrollCanvas" Height="24">
                                <TextBlock x:Name="PopupSongName"
                                           Text="无音频播放"
                                           Foreground="{DynamicResource TextPrimary}"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           VerticalAlignment="Center"/>
                            </Canvas>
                        </Grid>

                        <Button x:Name="PopupBtnQuickSelect"
                                Grid.Column="2"
                                Width="28" Height="28"
                                Background="Transparent"
                                Foreground="{DynamicResource Accent}"
                                BorderThickness="0"
                                Cursor="Hand"
                                FontSize="14"
                                FontWeight="Bold"
                                Content="#"
                                ToolTip="快速选择预设音频"
                                VerticalAlignment="Center"
                                Margin="0,0,0,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="{DynamicResource Accent}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource White}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="PopupCurrentTime"
                                   Grid.Column="0"
                                   Text="00:00"
                                   Foreground="{DynamicResource TextMuted}"
                                   FontSize="11"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                        <Slider x:Name="PopupProgressSlider"
                                Grid.Column="1"
                                Minimum="0"
                                Maximum="100"
                                Value="0"
                                IsMoveToPointEnabled="True"
                                VerticalAlignment="Center"
                                Margin="4,0"/>
                        <TextBlock x:Name="PopupTotalTime"
                                   Grid.Column="2"
                                   Text="00:00"
                                   Foreground="{DynamicResource TextMuted}"
                                   FontSize="11"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center">
                        <Button x:Name="PopupBtnLoop"
                                Width="32" Height="32"
                                Background="Transparent"
                                Foreground="{DynamicResource TextPrimary}"
                                BorderThickness="0"
                                Cursor="Hand"
                                FontSize="14"
                                Content="🔁"
                                ToolTip="顺序循环"
                                Margin="0,0,6,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="{DynamicResource GlassWhite}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button x:Name="PopupBtnPrev"
                                Width="32" Height="32"
                                Background="Transparent"
                                Foreground="{DynamicResource TextPrimary}"
                                BorderThickness="0"
                                Cursor="Hand"
                                FontSize="16"
                                Content="⏮"
                                Margin="0,0,4,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="{DynamicResource GlassWhite}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button x:Name="PopupBtnPlayPause"
                                Width="42" Height="42"
                                Background="{DynamicResource Accent}"
                                Foreground="{DynamicResource White}"
                                BorderThickness="0"
                                Cursor="Hand"
                                FontSize="20"
                                Content="▶"
                                Margin="4,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="21">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="{DynamicResource AccentLight}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button x:Name="PopupBtnNext"
                                Width="32" Height="32"
                                Background="Transparent"
                                Foreground="{DynamicResource TextPrimary}"
                                BorderThickness="0"
                                Cursor="Hand"
                                FontSize="16"
                                Content="⏭"
                                Margin="4,0,6,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="{DynamicResource GlassWhite}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center">

                            <Button x:Name="PopupBtnVolume"
                                    Width="32" Height="32"
                                    Background="Transparent"
                                    Foreground="{DynamicResource TextSecondary}"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    FontSize="14"
                                    ToolTip="音量调节"
                                    Margin="2,0,2,0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd"
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource GlassWhite}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <TextBlock x:Name="PopupVolumeIcon" Text="🔊" FontSize="14"/>
                            </Button>

                            <Popup x:Name="VolumeNestedPopup"
                                   PlacementTarget="{x:Reference PopupBtnVolume}"
                                   Placement="Top"
                                   HorizontalOffset="-34"
                                   VerticalOffset="-4"
                                   StaysOpen="False"
                                   AllowsTransparency="True">
                                <Border Background="Transparent" ClipToBounds="True" CornerRadius="10">
                                    <Border Background="{DynamicResource BgPanel}"
                                            CornerRadius="10"
                                            Padding="10,8"
                                            BorderBrush="{DynamicResource BorderColor}"
                                            BorderThickness="1">
                                        <Border.Effect>
                                            <DropShadowEffect Color="#000000" BlurRadius="12" ShadowDepth="3" Opacity="0.4"/>
                                        </Border.Effect>
                                        <StackPanel>
                                            <TextBlock x:Name="VolumeNestedLabel"
                                                       Text="70%"
                                                       Foreground="{DynamicResource TextPrimary}"
                                                       FontSize="13"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,0,0,6"/>
                                            <Slider x:Name="PopupVolumeNestedSlider"
                                                    Width="120"
                                                    Orientation="Horizontal"
                                                    Minimum="0"
                                                    Maximum="1"
                                                    Value="0"
                                                    IsMoveToPointEnabled="True"
                                                    VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </Border>
                            </Popup>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
                </Border>
            </Border>
        </Popup>

        <Popup x:Name="WidgetGalleryPopup"
               Placement="Center"
               StaysOpen="False"
               AllowsTransparency="True">
            <local2:WidgetGallery x:Name="WidgetGalleryControl"/>
        </Popup>

        <Popup x:Name="Button9DetailPopup"
               PlacementTarget="{x:Reference BottomBarWrap}"
               Placement="Top"
               HorizontalOffset="0"
               VerticalOffset="0"
               StaysOpen="False"
               AllowsTransparency="True"
               Opened="Button9DetailPopup_Opened"/>

        <Popup x:Name="WidgetManagePopup"
               Placement="Center"
               StaysOpen="False"
               AllowsTransparency="True"/>

        <Grid x:Name="BottomBarWrap"
              HorizontalAlignment="Center"
              VerticalAlignment="Bottom"
              Height="70">

            <Border x:Name="FrostedGlass"
                    CornerRadius="16"
                    Margin="8,4"
                    Background="{DynamicResource Overlay}">
                <Border.Effect>
                    <BlurEffect Radius="14" KernelType="Gaussian"/>
                </Border.Effect>
                <Border Margin="2"
                        CornerRadius="14"
                        Background="{DynamicResource OverlayLight}"/>
            </Border>

            <Border x:Name="BackgroundBlocker"
                    Background="{DynamicResource DesktopBg}"
                    Visibility="Collapsed"/>

            <Border x:Name="ConnectedTopLine"
                    Height="1"
                    VerticalAlignment="Top"
                    Background="{DynamicResource BorderColor}"
                    Visibility="Collapsed"/>

            <DockPanel x:Name="TaskBar"
                       VerticalAlignment="Center"
                       Margin="18,8,18,8"
                       LastChildFill="False">

                <Button x:Name="Button1"
                        Style="{DynamicResource SquareTaskbarButton}"
                        Margin="0,0,8,0">
                    <TextBlock Text="🏠" FontSize="20"
                               TextAlignment="Center"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Button>

                <Button x:Name="Button6"
                        Style="{DynamicResource SquareTaskbarButton}"
                        Margin="0,0,8,0">
                    <TextBlock Text="⚙" FontSize="20"
                               TextAlignment="Center"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Button>

                <Button x:Name="Button7"
                        Style="{DynamicResource SquareTaskbarButton}"
                        Margin="0,0,8,0">
                    <TextBlock Text="📁" FontSize="20"
                               TextAlignment="Center"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Button>

                <Button x:Name="Button4"
                        Style="{DynamicResource SquareTaskbarButton}"
                        Margin="0,0,8,0">
                    <TextBlock Text="📄" FontSize="20"
                               TextAlignment="Center"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Button>

                <Button x:Name="Button2"
                        Style="{DynamicResource SquareTaskbarButton}"
                        Margin="0,0,8,0">
                    <TextBlock Text="🖼" FontSize="20"
                               TextAlignment="Center"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Button>

                <Button x:Name="Button3"
                        Style="{DynamicResource SquareTaskbarButton}"
                        Margin="0,0,8,0">
                    <TextBlock Text="🎵" FontSize="20"
                               TextAlignment="Center"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Button>

                <Button x:Name="Button5"
                        Style="{DynamicResource SquareTaskbarButton}"
                        Margin="0,0,8,0">
                    <TextBlock Text="📅" FontSize="20"
                               TextAlignment="Center"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Button>

                <Border x:Name="Separator1"
                        Width="2"
                        CornerRadius="1"
                        Background="{DynamicResource GlassWhiteSubtle}"
                        Margin="4,8,8,8"/>

                <Button x:Name="Button8"
                        Style="{DynamicResource RectTaskbarButton}"
                        Margin="0,0,0,0">
                    <TextBlock x:Name="Btn8Text"
                               Text="音频控制"
                               FontSize="12"
                               Foreground="{DynamicResource White}"
                               TextAlignment="Center"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Button>

                <Border x:Name="Separator2"
                        Width="2"
                        CornerRadius="1"
                        Background="{DynamicResource GlassWhiteSubtle}"
                        Margin="8,8,8,8"/>

                <Button x:Name="Button9"
                        MinWidth="80"
                        Height="42"
                        Background="Transparent"
                        Foreground="{DynamicResource White}"
                        BorderThickness="0"
                        Cursor="Hand"
                        Padding="8,4">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="10"
                                    BorderThickness="0">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="{DynamicResource GlassWhite}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="{DynamicResource GlassWhiteBold}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <TextBlock x:Name="Btn9Text"
                               Text="00:00:00"
                               FontSize="12"
                               Foreground="{DynamicResource White}"
                               TextAlignment="Center"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Button>

                <Button x:Name="Button10"
                        Width="10"
                        Height="42"
                        Background="Transparent"
                        Foreground="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        Margin="4,0,0,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="1">
                                <ContentPresenter/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

            </DockPanel>
        </Grid>
    </Grid>
</UserControl>
