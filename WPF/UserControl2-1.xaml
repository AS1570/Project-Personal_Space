<UserControl x:Class="WpfApp3.UserControl2_1"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WpfApp3"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200">
    <UserControl.Resources>
        <Style x:Key="ToolbarButton" TargetType="Button">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource BgHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource BgDark}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource BgPanel}"
                BorderBrush="{DynamicResource BorderColor}"
                BorderThickness="0,0,0,1"
                Padding="8,4">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button x:Name="BtnHide"
                        Style="{DynamicResource ToolbarButton}"
                        ToolTip="关闭">
                    <TextBlock Text="✕"/>
                </Button>
                <Separator Width="1"
                           Background="{DynamicResource BorderColor}"
                           Margin="6,6"/>
                <Button x:Name="BtnRotateLeft"
                        Style="{DynamicResource ToolbarButton}"
                        ToolTip="向左旋转90°">
                    <TextBlock Text="↺"/>
                </Button>
                <Button x:Name="BtnRotateRight"
                        Style="{DynamicResource ToolbarButton}"
                        ToolTip="向右旋转90°">
                    <TextBlock Text="↻"/>
                </Button>
                <Separator Width="1"
                           Background="{DynamicResource BorderColor}"
                           Margin="6,6"/>
                <Button x:Name="BtnZoomOut"
                        Style="{DynamicResource ToolbarButton}"
                        ToolTip="缩小">
                    <TextBlock Text="−"/>
                </Button>
                <TextBlock x:Name="ZoomPercentLabel"
                           Text="100%"
                           Foreground="{DynamicResource TextSecondary}"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Width="44"
                           TextAlignment="Center"/>
                <Button x:Name="BtnZoomIn"
                        Style="{DynamicResource ToolbarButton}"
                        ToolTip="放大">
                    <TextBlock Text="+"/>
                </Button>
                <Separator Width="1"
                           Background="{DynamicResource BorderColor}"
                           Margin="6,6"/>
                <Button x:Name="BtnFitToWindow"
                        Style="{DynamicResource ToolbarButton}"
                        ToolTip="适应窗口">
                    <TextBlock Text="⊞"/>
                </Button>
                <Separator Width="1"
                           Background="{DynamicResource BorderColor}"
                           Margin="6,6"/>
                <Button x:Name="BtnZoom100"
                        Style="{DynamicResource ToolbarButton}"
                        ToolTip="100%原始大小">
                    <TextBlock Text="1:1"/>
                </Button>
                <Separator Width="1"
                           Background="{DynamicResource BorderColor}"
                           Margin="6,6"/>
                <Button x:Name="BtnFullscreen"
                        Style="{DynamicResource ToolbarButton}"
                        ToolTip="全屏">
                    <TextBlock Text="⛶"/>
                </Button>
                </StackPanel>
                <Button x:Name="BtnToggleLeftPanel"
                        Style="{DynamicResource ToolbarButton}"
                        ToolTip="隐藏左侧面板"
                        HorizontalAlignment="Right">
                    <TextBlock Text="◀"/>
                </Button>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Background="{DynamicResource BgPanel}"
                Padding="12,6">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="FileNameLabel"
                           Text="--"
                           Foreground="{DynamicResource TextPrimary}"
                           FontSize="13"
                           FontWeight="SemiBold"/>
                <TextBlock x:Name="FileSaveTimeLabel"
                           Text=""
                           Foreground="{DynamicResource TextSecondary}"
                           FontSize="12"
                           Margin="16,0,0,0"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Background="{DynamicResource BgDark}">
            <ScrollViewer x:Name="ImageScrollViewer"
                          HorizontalScrollBarVisibility="Hidden"
                          VerticalScrollBarVisibility="Hidden"
                          CanContentScroll="False">
                <Image x:Name="ImageViewer"
                       Stretch="Uniform">
                    <Image.LayoutTransform>
                        <RotateTransform x:Name="ImageRotateTransform"
                                         Angle="0"/>
                    </Image.LayoutTransform>
                </Image>
            </ScrollViewer>
        </Border>

        <Border Grid.Row="3"
                Background="{DynamicResource BgPanel}"
                Padding="12,6">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="DimensionsLabel"
                           Text="-- × --"
                           Foreground="{DynamicResource TextSecondary}"
                           FontSize="12"/>
                <TextBlock Text=" · "
                           Foreground="{DynamicResource TextMuted}"
                           FontSize="12"/>
                <TextBlock x:Name="FileSizeLabel"
                           Text="--"
                           Foreground="{DynamicResource TextSecondary}"
                           FontSize="12"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
