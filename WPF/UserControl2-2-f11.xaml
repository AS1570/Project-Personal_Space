<UserControl x:Class="WpfApp3.UserControl2_2_f11"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Black">
    <UserControl.Resources>
        <Style x:Key="F11ControlButton" TargetType="Button">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource GlassWhite}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid x:Name="FullscreenRoot">
        <MediaElement x:Name="VideoPlayer"
                      LoadedBehavior="Manual"
                      Stretch="Uniform"
                      Volume="0.5"/>

        <Border x:Name="TopInfoBar"
                Background="{DynamicResource BgDeep}"
                VerticalAlignment="Top"
                Padding="12,8"
                Opacity="0">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="FileNameLabel"
                           Text="--"
                           Foreground="{DynamicResource TextPrimary}"
                           FontSize="13"
                           FontWeight="SemiBold"/>
                <TextBlock x:Name="DimensionsLabel"
                           Text="-- × --"
                           Foreground="{DynamicResource TextSecondary}"
                           FontSize="12"
                           Margin="16,0,0,0"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <Border x:Name="BottomToolbar"
                Background="{DynamicResource BgDeep}"
                VerticalAlignment="Bottom"
                Opacity="0">
            <StackPanel Margin="20,10">
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="42"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="42"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="CurrentTimeLabel"
                               Grid.Column="0"
                               Text="00:00"
                               Foreground="{DynamicResource TextSecondary}"
                               FontSize="11"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>
                    <Slider x:Name="ProgressSlider"
                            Grid.Column="1"
                            Minimum="0"
                            Maximum="100"
                            Value="0"
                            IsMoveToPointEnabled="True"
                            VerticalAlignment="Center"
                            Margin="8,0"/>
                    <TextBlock x:Name="TotalTimeLabel"
                               Grid.Column="2"
                               Text="00:00"
                               Foreground="{DynamicResource TextSecondary}"
                               FontSize="11"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>
                </Grid>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="BtnRewind"
                            Style="{DynamicResource F11ControlButton}"
                            ToolTip="后退5秒">
                        <TextBlock Text="⏪" FontSize="12"/>
                    </Button>
                    <Button x:Name="BtnPlay"
                            Style="{DynamicResource F11ControlButton}"
                            Width="42" Height="42"
                            Margin="8,0"
                            ToolTip="播放/暂停">
                        <TextBlock Text="▶" FontSize="18" TextAlignment="Center"/>
                    </Button>
                    <Button x:Name="BtnForward"
                            Style="{DynamicResource F11ControlButton}"
                            ToolTip="前进5秒">
                        <TextBlock Text="⏩" FontSize="12"/>
                    </Button>

                    <Border Width="1"
                            Background="{DynamicResource GlassWhite44}"
                            Margin="14,6"/>

                    <TextBlock x:Name="VolumeIcon"
                               Text="🔊"
                               FontSize="14"
                               Foreground="{DynamicResource TextPrimary}"
                               VerticalAlignment="Center"
                               Margin="0,0,4,0"/>
                    <Slider x:Name="VolumeSlider"
                            Width="80"
                            Minimum="0"
                            Maximum="1"
                            Value="0.5"
                            IsMoveToPointEnabled="True"
                            VerticalAlignment="Center"/>

                    <Border Width="1"
                            Background="{DynamicResource GlassWhite44}"
                            Margin="14,6"/>

                    <Button x:Name="BtnSpeed"
                            Style="{DynamicResource F11ControlButton}"
                            ToolTip="播放速度">
                        <TextBlock x:Name="SpeedLabel" Text="1x" FontSize="12"/>
                    </Button>

                    <Border Width="1"
                            Background="{DynamicResource GlassWhite44}"
                            Margin="14,6"/>

                    <Button x:Name="BtnExitFullscreen"
                            Style="{DynamicResource F11ControlButton}"
                            ToolTip="退出全屏">
                        <TextBlock Text="✕" FontSize="14"/>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
