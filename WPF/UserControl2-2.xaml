<UserControl x:Class="WpfApp3.UserControl2_2"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WpfApp3"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200">
    <UserControl.Resources>
        <Style x:Key="VideoToolbarButton" TargetType="Button">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource BgHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ControlButton" TargetType="Button">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource BgHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource BgDark}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource BgPanel}"
                BorderBrush="{DynamicResource BorderColor}"
                BorderThickness="0,0,0,1"
                Padding="8,4">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button x:Name="BtnHide"
                        Style="{DynamicResource VideoToolbarButton}"
                        ToolTip="关闭">
                    <TextBlock Text="✕"/>
                </Button>
                <TextBlock x:Name="FileNameLabel"
                           Text="--"
                           Foreground="{DynamicResource TextPrimary}"
                           FontSize="13"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0"/>
                </StackPanel>
                <Button x:Name="BtnToggleLeftPanel"
                        Style="{DynamicResource VideoToolbarButton}"
                        ToolTip="隐藏左侧面板"
                        HorizontalAlignment="Right">
                    <TextBlock Text="◀"/>
                </Button>
            </Grid>
        </Border>

        <Border x:Name="VideoArea" Grid.Row="1"
                Background="Black">
            <MediaElement x:Name="VideoPlayer"
                          LoadedBehavior="Manual"
                          Stretch="Uniform"
                          Volume="0.5"/>
        </Border>

        <Border Grid.Row="2"
                Background="{DynamicResource BgPanel}"
                Padding="12,6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="40"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="CurrentTimeLabel"
                               Grid.Column="0"
                               Text="00:00"
                               Foreground="{DynamicResource TextSecondary}"
                               FontSize="11"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>
                    <Slider x:Name="ProgressSlider"
                            Grid.Column="1"
                            Minimum="0"
                            Maximum="100"
                            Value="0"
                            IsMoveToPointEnabled="True"
                            VerticalAlignment="Center"
                            Margin="8,0"/>
                    <TextBlock x:Name="TotalTimeLabel"
                               Grid.Column="2"
                               Text="00:00"
                               Foreground="{DynamicResource TextSecondary}"
                               FontSize="11"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>
                </Grid>

                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="BtnRewind"
                            Style="{DynamicResource ControlButton}"
                            ToolTip="后退5秒">
                        <TextBlock Text="⏪" FontSize="12"/>
                    </Button>
                    <Button x:Name="BtnPlay"
                            Style="{DynamicResource ControlButton}"
                            Width="42" Height="42"
                            Margin="8,0"
                            ToolTip="播放/暂停">
                        <TextBlock Text="▶" FontSize="18" TextAlignment="Center"/>
                    </Button>
                    <Button x:Name="BtnForward"
                            Style="{DynamicResource ControlButton}"
                            ToolTip="前进5秒">
                        <TextBlock Text="⏩" FontSize="12"/>
                    </Button>

                    <Border Width="1"
                            Background="{DynamicResource BorderColor}"
                            Margin="12,6"/>

                    <TextBlock x:Name="VolumeIcon"
                               Text="🔊"
                               FontSize="14"
                               VerticalAlignment="Center"
                               Margin="0,0,4,0" Foreground="{DynamicResource TextPrimary}"/>
                    <Slider x:Name="VolumeSlider"
                            Width="80"
                            Minimum="0"
                            Maximum="1"
                            Value="0.5"
                            IsMoveToPointEnabled="True"
                            VerticalAlignment="Center"/>
                    <TextBlock x:Name="VolumeLabel"
                               Text="50%"
                               Foreground="{DynamicResource TextSecondary}"
                               FontSize="11"
                               VerticalAlignment="Center"
                               Margin="4,0,0,0"/>

                    <Border Width="1"
                            Background="{DynamicResource BorderColor}"
                            Margin="12,6"/>

                    <Button x:Name="BtnSpeed"
                            Style="{DynamicResource ControlButton}"
                            ToolTip="播放速度">
                        <TextBlock x:Name="SpeedLabel" Text="1x" FontSize="12"/>
                    </Button>

                    <Border Width="1"
                            Background="{DynamicResource BorderColor}"
                            Margin="12,6"/>

                    <Button x:Name="BtnFullscreen"
                            Style="{DynamicResource ControlButton}"
                            ToolTip="全屏">
                        <TextBlock Text="⛶" FontSize="14"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="3"
                Background="{DynamicResource BgPanel}"
                Padding="12,6">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="DimensionsLabel"
                           Text="-- × --"
                           Foreground="{DynamicResource TextSecondary}"
                           FontSize="12"/>
                <TextBlock Text=" · "
                           Foreground="{DynamicResource TextMuted}"
                           FontSize="12"/>
                <TextBlock x:Name="FileSizeLabel"
                           Text="--"
                           Foreground="{DynamicResource TextSecondary}"
                           FontSize="12"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
