<UserControl x:Class="WpfApp3.UserControl4"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WpfApp3"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1000">
    <UserControl.Resources>
        <local:FileSizeConverter x:Key="FileSizeConverter"/>

        <Style x:Key="DarkButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource BgSurface}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderLight}"/>
            <Setter Property="BorderThickness" Value="0.5"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource BgHover}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource Accent}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{DynamicResource BgPressed}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="{DynamicResource BgSurface}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderLight}"/>
            <Setter Property="BorderThickness" Value="0.5"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource BgHover}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ToggleTrack}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource Accent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource BgSurface}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderLight}"/>
            <Setter Property="BorderThickness" Value="0.5"/>
            <Setter Property="CaretBrush" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource Accent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer>
                                <ItemsPresenter/>
                            </ScrollViewer>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                        <Setter Property="Padding" Value="10,6"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}"
                                            CornerRadius="4"
                                            Margin="4,1">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource BgHover}"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource ToggleTrack}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource Accent}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkScrollViewerStyle" TargetType="ScrollViewer">
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <Style x:Key="DarkComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource BgSurface}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderLight}"/>
            <Setter Property="BorderThickness" Value="0.5"/>
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="20"/>
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0"
                                                                  Margin="6,3"
                                                                  Content="{TemplateBinding Content}"
                                                                  ContentTemplate="{TemplateBinding ContentTemplate}"/>
                                                <Path Grid.Column="1"
                                                      Data="M0,0 L4,4 L8,0"
                                                      Fill="{DynamicResource TextSecondary}"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Stroke="{DynamicResource TextSecondary}"
                                                      StrokeThickness="1"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   PopupAnimation="Slide"
                                   AllowsTransparency="True">
                                <Border Background="{DynamicResource BgSurface}"
                                        BorderBrush="{DynamicResource BorderLight}"
                                        BorderThickness="0.5"
                                        CornerRadius="4"
                                        Margin="0,2,0,0">
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource BgDark}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3.5*"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="6.5*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{DynamicResource BgPanel}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Padding="8,8,8,4">
                    <TextBox x:Name="SearchTextBox"
                             Style="{DynamicResource DarkTextBoxStyle}"
                             TextChanged="SearchTextBox_TextChanged"
                             Tag="搜索文件..."/>
                </Border>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="8,0,8,4">
                    <Button x:Name="NewFileButton"
                            Style="{DynamicResource DarkButtonStyle}"
                            Content="📄 新建txt"
                            ToolTip="新建文本文件"
                            FontSize="12"
                            Padding="8,4"
                            Click="NewFileButton_Click"/>
                    <TextBlock Text="文本文件"
                               Foreground="{DynamicResource TextSecondary}"
                               VerticalAlignment="Center"
                               Margin="8,0,0,0"
                               FontSize="11"/>
                </StackPanel>

                <ListBox x:Name="FileListBox"
                         Grid.Row="2"
                         Style="{DynamicResource DarkListBoxStyle}"
                         SelectionChanged="FileListBox_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding DisplayName}"
                                               Foreground="{DynamicResource TextPrimary}"
                                               FontSize="13"/>
                                    <TextBlock Text="{Binding FileSize, Converter={StaticResource FileSizeConverter}}"
                                               Foreground="{DynamicResource TextSecondary}"
                                               FontSize="11"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Extension}"
                                           Foreground="{DynamicResource Accent}"
                                           FontSize="11"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <GridSplitter Grid.Column="1"
                      Width="5"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      Background="Transparent"
                      ResizeBehavior="PreviousAndNext"/>

        <Border Grid.Column="2" Background="{DynamicResource BgDark}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{DynamicResource BgPanel}"
                        Padding="10,6"
                        BorderBrush="{DynamicResource BorderAlt}"
                        BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="FileNameLabel"
                                   Grid.Column="0"
                                   Text="未打开文件"
                                   Foreground="{DynamicResource TextPrimary}"
                                   FontSize="14"
                                   VerticalAlignment="Center"/>

                        <TextBlock x:Name="FileExtensionLabel"
                                   Grid.Column="1"
                                   Text=""
                                   Foreground="{DynamicResource Accent}"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   Margin="4,0,0,0"/>

                        <TextBlock x:Name="FileModifiedIndicator"
                                   Grid.Column="2"
                                   Text="●"
                                   Foreground="{DynamicResource Accent}"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   Margin="6,0,0,0"
                                   Visibility="Collapsed"/>

                        <Button x:Name="ToggleLeftPanelButton"
                                Grid.Column="4"
                                Content="☰"
                                Style="{DynamicResource DarkButtonStyle}"
                                Click="ToggleLeftPanelButton_Click"
                                Width="32" Height="26"
                                Padding="0"
                                ToolTip="隐藏/显示文件列表"/>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Background="{DynamicResource BgPanel}"
                        Padding="8,4"
                        BorderBrush="{DynamicResource BorderAlt}"
                        BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="SaveButton"
                                Grid.Column="0"
                                Content="💾"
                                Style="{DynamicResource DarkButtonStyle}"
                                Click="SaveButton_Click"
                                ToolTip="保存 (Ctrl+S)"
                                Width="32" Height="26"
                                Padding="0"/>

                        <Button x:Name="UndoButton"
                                Grid.Column="1"
                                Content="↩"
                                Style="{DynamicResource DarkButtonStyle}"
                                Click="UndoButton_Click"
                                ToolTip="撤销 (Ctrl+Z)"
                                Width="32" Height="26"
                                Padding="0"
                                Margin="4,0,0,0"/>

                        <Button x:Name="RedoButton"
                                Grid.Column="2"
                                Content="↪"
                                Style="{DynamicResource DarkButtonStyle}"
                                Click="RedoButton_Click"
                                ToolTip="重做 (Ctrl+Y)"
                                Width="32" Height="26"
                                Padding="0"
                                Margin="4,0,0,0"/>

                        <Border Grid.Column="4"
                                Background="Transparent"
                                Width="32" Height="26">
                            <Button x:Name="CloseFileButton"
                                    Content="✕"
                                    Style="{DynamicResource DarkButtonStyle}"
                                    Click="CloseFileButton_Click"
                                    ToolTip="关闭文件"
                                    Width="32" Height="26"
                                    Padding="0"/>
                        </Border>

                        <Button x:Name="SaveCopyButton"
                                Grid.Column="5"
                                Content="📋"
                                Style="{DynamicResource DarkButtonStyle}"
                                Click="SaveCopyButton_Click"
                                ToolTip="保存副本"
                                Width="32" Height="26"
                                Padding="0"
                                Margin="4,0,0,0"/>
                    </Grid>
                </Border>

                <Border x:Name="FindReplacePanel"
                        Grid.Row="2"
                        Background="{DynamicResource BgPanel}"
                        Padding="8,6"
                        BorderBrush="{DynamicResource BorderAlt}"
                        BorderThickness="0,0,0,1"
                        Visibility="Collapsed">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="查找:"
                                       Foreground="{DynamicResource TextSecondary}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,6,0"
                                       FontSize="12"/>

                            <TextBox x:Name="FindTextBox"
                                     Grid.Column="1"
                                     Style="{DynamicResource DarkTextBoxStyle}"
                                     TextChanged="FindTextBox_TextChanged"
                                     FontSize="12"
                                     Padding="4,3"/>

                            <TextBlock Grid.Column="2"
                                       Text="替换:"
                                       Foreground="{DynamicResource TextSecondary}"
                                       VerticalAlignment="Center"
                                       Margin="12,0,6,0"
                                       FontSize="12"/>

                            <TextBox x:Name="ReplaceTextBox"
                                     Grid.Column="3"
                                     Style="{DynamicResource DarkTextBoxStyle}"
                                     Width="200"
                                     FontSize="12"
                                     Padding="4,3"/>

                            <Button x:Name="FindNextButton"
                                    Grid.Column="4"
                                    Content="▼ 下一个"
                                    Style="{DynamicResource DarkButtonStyle}"
                                    Click="FindNextButton_Click"
                                    FontSize="11"
                                    Margin="12,0,0,0"/>

                            <Button x:Name="FindPrevButton"
                                    Grid.Column="5"
                                    Content="▲ 上一个"
                                    Style="{DynamicResource DarkButtonStyle}"
                                    Click="FindPrevButton_Click"
                                    FontSize="11"
                                    Margin="4,0,0,0"/>

                            <Button x:Name="ReplaceAllButton"
                                    Grid.Column="7"
                                    Content="全部替换"
                                    Style="{DynamicResource DarkButtonStyle}"
                                    Click="ReplaceAllButton_Click"
                                    FontSize="11"/>
                        </Grid>

                        <TextBlock x:Name="FindStatusText"
                                   Grid.Row="1"
                                   Foreground="{DynamicResource TextSecondary}"
                                   FontSize="11"
                                   Margin="0,4,0,0"/>
                    </Grid>
                </Border>

                <TextBox x:Name="EditorTextBox"
                         Grid.Row="3"
                         Background="{DynamicResource EditorBg}"
                         Foreground="{DynamicResource TextPrimary}"
                         BorderThickness="0"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         TextWrapping="Wrap"
                         FontFamily="Consolas"
                         FontSize="14"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         SelectionChanged="EditorTextBox_SelectionChanged"
                         TextChanged="EditorTextBox_TextChanged"
                         KeyDown="EditorTextBox_KeyDown"
                         PreviewKeyDown="EditorTextBox_PreviewKeyDown"
                         PreviewMouseWheel="EditorTextBox_PreviewMouseWheel"
                         Padding="8,6"/>

                <Border Grid.Row="4"
                        Background="{DynamicResource BgPanel}"
                        Padding="8,4"
                        BorderBrush="{DynamicResource BorderAlt}"
                        BorderThickness="0,1,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="CursorInfoLabel"
                                   Grid.Column="0"
                                   Text="行 1, 列 1"
                                   Foreground="{DynamicResource TextSecondary}"
                                   FontSize="11"
                                   VerticalAlignment="Center"
                                   Margin="0,0,12,0"/>

                        <TextBlock x:Name="CharCountLabel"
                                   Grid.Column="1"
                                   Text="字符: 0"
                                   Foreground="{DynamicResource TextSecondary}"
                                   FontSize="11"
                                   VerticalAlignment="Center"
                                   Margin="0,0,12,0"/>

                        <TextBlock x:Name="SelectedCharCountLabel"
                                   Grid.Column="2"
                                   Text=""
                                   Foreground="{DynamicResource Accent}"
                                   FontSize="11"
                                   VerticalAlignment="Center"
                                   Margin="0,0,12,0"/>

                        <ToggleButton x:Name="WordWrapToggleButton"
                                      Grid.Column="4"
                                      Content="↩"
                                      Style="{DynamicResource DarkToggleButtonStyle}"
                                      IsChecked="True"
                                      Click="WordWrapToggleButton_Click"
                                      ToolTip="切换自动换行"
                                      Width="28" Height="22"
                                      Padding="0"
                                      FontSize="12"/>

                        <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,6,0">
                            <Button x:Name="ZoomOutButton"
                                    Content="−"
                                    Style="{DynamicResource DarkButtonStyle}"
                                    Click="ZoomOutButton_Click"
                                    ToolTip="缩小"
                                    Width="24" Height="22"
                                    Padding="0"
                                    FontSize="12"/>
                            <TextBlock x:Name="ZoomRatioLabel"
                                       Text="100%"
                                       Foreground="{DynamicResource TextSecondary}"
                                       FontSize="11"
                                       VerticalAlignment="Center"
                                       Margin="4,0"/>
                            <Button x:Name="ZoomInButton"
                                    Content="+"
                                    Style="{DynamicResource DarkButtonStyle}"
                                    Click="ZoomInButton_Click"
                                    ToolTip="放大"
                                    Width="24" Height="22"
                                    Padding="0"
                                    FontSize="12"/>
                        </StackPanel>

                        <TextBlock x:Name="EncodingLabel"
                                   Grid.Column="6"
                                   Text="UTF-8"
                                   Foreground="{DynamicResource TextSecondary}"
                                   FontSize="11"
                                   VerticalAlignment="Center"
                                   Margin="12,0,4,0"/>

                        <ComboBox x:Name="EncodingComboBox"
                                  Grid.Column="7"
                                  Style="{DynamicResource DarkComboBoxStyle}"
                                  Width="100"
                                  FontSize="11"
                                  SelectionChanged="EncodingComboBox_SelectionChanged">
                            <ComboBoxItem Content="UTF-8" Tag="utf-8"/>
                            <ComboBoxItem Content="UTF-16 LE" Tag="utf-16le"/>
                            <ComboBoxItem Content="GB2312" Tag="gb2312"/>
                            <ComboBoxItem Content="ASCII" Tag="ascii"/>
                        </ComboBox>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
