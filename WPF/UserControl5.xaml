<UserControl x:Class="WpfApp3.UserControl5"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WpfApp3"
             mc:Ignorable="d"
             d:DesignHeight="650" d:DesignWidth="1100">
    <UserControl.Resources>
        <Style x:Key="DarkButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource BgSurface}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderLight}"/>
            <Setter Property="BorderThickness" Value="0.5"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource BgHover}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource Accent}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{DynamicResource BgPressed}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="{DynamicResource BgSurface}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderLight}"/>
            <Setter Property="BorderThickness" Value="0.5"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource BgHover}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ToggleTrack}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource Accent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource BgSurface}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderLight}"/>
            <Setter Property="BorderThickness" Value="0.5"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="20"/>
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0"
                                                                  Margin="6,3"
                                                                  Content="{TemplateBinding Content}"
                                                                  ContentTemplate="{TemplateBinding ContentTemplate}"/>
                                                <Path Grid.Column="1"
                                                      Data="M0,0 L4,4 L8,0"
                                                      Fill="{DynamicResource TextSecondary}"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Stroke="{DynamicResource TextSecondary}"
                                                      StrokeThickness="1"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite"
                                              IsHitTestVisible="False"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              Margin="10,3,24,3"
                                              TextBlock.Foreground="{TemplateBinding Foreground}"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"/>
                            <Popup IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   PopupAnimation="Slide"
                                   AllowsTransparency="True">
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="0.5"
                                        CornerRadius="4"
                                        Margin="0,2,0,0">
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkNavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource BgHover}"/>
                                <Setter Property="Foreground" Value="{DynamicResource Accent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource BgDark}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="76*"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="143*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{DynamicResource BgPanel}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Padding="12,10,12,8"
                        BorderBrush="{DynamicResource BorderAlt}"
                        BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="PrevMonthButton"
                                Grid.Column="0"
                                Content="◀"
                                Style="{DynamicResource DarkNavButtonStyle}"
                                Click="PrevMonthButton_Click"
                                ToolTip="上一月"
                                Width="36" Height="32"
                                Padding="0"/>

                        <TextBlock x:Name="MonthYearLabel"
                                   Grid.Column="1"
                                   Text="2026年 6月"
                                   Foreground="{DynamicResource TextPrimary}"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>

                        <Button x:Name="NextMonthButton"
                                Grid.Column="2"
                                Content="▶"
                                Style="{DynamicResource DarkNavButtonStyle}"
                                Click="NextMonthButton_Click"
                                ToolTip="下一月"
                                Width="36" Height="32"
                                Padding="0"/>

                        <Button x:Name="TodayButton"
                                Grid.Column="3"
                                Content="今天"
                                Style="{DynamicResource DarkButtonStyle}"
                                Click="TodayButton_Click"
                                ToolTip="回到本月"
                                FontSize="13"
                                Padding="10,5"
                                Margin="8,0,0,0"/>
                    </Grid>
                </Border>

                <Border x:Name="CalendarGridHolder"
                        Grid.Row="1"
                        Padding="4"/>

                <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,8,0,10">
                    <Button x:Name="ExportMonthButton"
                            Content="📄 导出本月"
                            Style="{DynamicResource DarkButtonStyle}"
                            Click="ExportMonthButton_Click"
                            ToolTip="导出本月所有日记为文本文件"
                            FontSize="12"
                            Padding="12,6"
                            Margin="0,0,8,0"/>
                    <Button x:Name="ExportYearButton"
                            Content="📁 导出本年"
                            Style="{DynamicResource DarkButtonStyle}"
                            Click="ExportYearButton_Click"
                            ToolTip="导出本年度所有日记为文本文件"
                            FontSize="12"
                            Padding="12,6"/>
                </StackPanel>
            </Grid>
        </Border>

        <GridSplitter Grid.Column="1"
                      Width="5"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      Background="Transparent"
                      ResizeBehavior="PreviousAndNext"/>

        <Border Grid.Column="2" Background="{DynamicResource BgDark}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{DynamicResource BgPanel}"
                        Padding="10,6"
                        BorderBrush="{DynamicResource BorderAlt}"
                        BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="SaveButton"
                                Content="💾 保存"
                                Style="{DynamicResource DarkButtonStyle}"
                                Click="SaveButton_Click"
                                ToolTip="保存日记 (Ctrl+S)"
                                FontSize="12"
                                Padding="8,4"/>
                        <Button x:Name="UndoButton"
                                Content="↩ 撤销"
                                Style="{DynamicResource DarkButtonStyle}"
                                Click="UndoButton_Click"
                                ToolTip="撤销 (Ctrl+Z)"
                                FontSize="12"
                                Padding="8,4"
                                Margin="4,0,0,0"/>
                        <Button x:Name="RedoButton"
                                Content="↪ 重做"
                                Style="{DynamicResource DarkButtonStyle}"
                                Click="RedoButton_Click"
                                ToolTip="重做 (Ctrl+Y)"
                                FontSize="12"
                                Padding="8,4"
                                Margin="4,0,0,0"/>

                        <Separator Style="{DynamicResource {x:Static ToolBar.SeparatorStyleKey}}"
                                   Margin="8,2" Background="{DynamicResource BorderLight}" Width="1"/>

                        <Button x:Name="ZoomOutButton"
                                Content="−"
                                Style="{DynamicResource DarkButtonStyle}"
                                Click="ZoomOutButton_Click"
                                ToolTip="缩小字体"
                                Width="32" Height="26"
                                Padding="0"
                                FontSize="14"/>
                        <Button x:Name="ZoomInButton"
                                Content="+"
                                Style="{DynamicResource DarkButtonStyle}"
                                Click="ZoomInButton_Click"
                                ToolTip="放大字体"
                                Width="32" Height="26"
                                Padding="0"
                                FontSize="14"
                                Margin="2,0,0,0"/>

                        <Separator Style="{DynamicResource {x:Static ToolBar.SeparatorStyleKey}}"
                                   Margin="8,2" Background="{DynamicResource BorderLight}" Width="1"/>

                        <Button x:Name="ExportTodayButton"
                                Content="📋 导出今日"
                                Style="{DynamicResource DarkButtonStyle}"
                                Click="ExportTodayButton_Click"
                                ToolTip="导出当前日记为文本文件"
                                FontSize="12"
                                Padding="8,4"/>

                        <Button x:Name="CloseButton"
                                Content="✕ 关闭"
                                Style="{DynamicResource DarkButtonStyle}"
                                Click="CloseButton_Click"
                                ToolTip="关闭当前日记"
                                FontSize="12"
                                Padding="8,4"
                                Margin="4,0,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1"
                        Background="{DynamicResource BgPanel}"
                        Padding="10,6"
                        BorderBrush="{DynamicResource BorderAlt}"
                        BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="SelectedDateLabel"
                                   Grid.Column="0"
                                   Text="未选择日期"
                                   Foreground="{DynamicResource TextPrimary}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Margin="0,0,16,0"/>

                        <TextBlock Grid.Column="2"
                                   Text="天气"
                                   Foreground="{DynamicResource TextSecondary}"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   Margin="0,0,6,0"/>

                        <ComboBox x:Name="WeatherComboBox"
                                  Grid.Column="3"
                                  Style="{DynamicResource DarkComboBoxStyle}"
                                  Width="90"
                                  FontSize="12"
                                  Padding="4,3"
                                  SelectionChanged="WeatherComboBox_SelectionChanged"
                                  ToolTip="选择天气">
                            <ComboBox.ItemContainerStyle>
                                <Style TargetType="ComboBoxItem">
                                    <Setter Property="Background" Value="{DynamicResource BgDeep}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                                    <Setter Property="Padding" Value="6,4"/>
                                </Style>
                            </ComboBox.ItemContainerStyle>
                        </ComboBox>

                        <TextBlock Grid.Column="4"
                                   Text="心情"
                                   Foreground="{DynamicResource TextSecondary}"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   Margin="10,0,6,0"/>

                        <ComboBox x:Name="MoodComboBox"
                                  Grid.Column="5"
                                  Style="{DynamicResource DarkComboBoxStyle}"
                                  Width="90"
                                  FontSize="12"
                                  Padding="4,3"
                                  SelectionChanged="MoodComboBox_SelectionChanged"
                                  ToolTip="选择心情">
                            <ComboBox.ItemContainerStyle>
                                <Style TargetType="ComboBoxItem">
                                    <Setter Property="Background" Value="{DynamicResource BgDeep}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                                    <Setter Property="Padding" Value="6,4"/>
                                </Style>
                            </ComboBox.ItemContainerStyle>
                        </ComboBox>

                        <Button x:Name="MoodSizeDownButton"
                                Grid.Column="6"
                                Content="−"
                                Style="{DynamicResource DarkButtonStyle}"
                                Click="MoodSizeDownButton_Click"
                                ToolTip="缩小心情图标"
                                Width="24" Height="24"
                                Padding="0"
                                FontSize="10"
                                Margin="4,0,0,0"
                                Visibility="Collapsed"/>

                        <Button x:Name="MoodSizeUpButton"
                                Grid.Column="7"
                                Content="+"
                                Style="{DynamicResource DarkButtonStyle}"
                                Click="MoodSizeUpButton_Click"
                                ToolTip="放大小情图标"
                                Width="24" Height="24"
                                Padding="0"
                                FontSize="10"
                                Margin="2,0,0,0"
                                Visibility="Collapsed"/>
                    </Grid>
                </Border>

                <TextBox x:Name="DiaryTextBox"
                         Grid.Row="2"
                         Background="{DynamicResource EditorBg}"
                         Foreground="{DynamicResource TextPrimary}"
                         BorderThickness="0"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         TextWrapping="Wrap"
                         FontFamily="Consolas"
                         FontSize="14"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         SelectionChanged="DiaryTextBox_SelectionChanged"
                         TextChanged="DiaryTextBox_TextChanged"
                         KeyDown="DiaryTextBox_KeyDown"
                         PreviewKeyDown="DiaryTextBox_PreviewKeyDown"
                         PreviewMouseWheel="DiaryTextBox_PreviewMouseWheel"
                         Padding="10,8"/>

                <Border Grid.Row="3"
                        Background="{DynamicResource BgPanel}"
                        Padding="10,5"
                        BorderBrush="{DynamicResource BorderAlt}"
                        BorderThickness="0,1,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="CursorInfoLabel"
                                   Grid.Column="0"
                                   Text="行 1, 列 1"
                                   Foreground="{DynamicResource TextSecondary}"
                                   FontSize="11"
                                   VerticalAlignment="Center"
                                   Margin="0,0,12,0"/>

                        <TextBlock x:Name="CharCountLabel"
                                   Grid.Column="1"
                                   Text="字数: 0"
                                   Foreground="{DynamicResource TextSecondary}"
                                   FontSize="11"
                                   VerticalAlignment="Center"
                                   Margin="0,0,12,0"/>

                        <TextBlock x:Name="SelectedCharCountLabel"
                                   Grid.Column="2"
                                   Text=""
                                   Foreground="{DynamicResource Accent}"
                                   FontSize="11"
                                   VerticalAlignment="Center"
                                   Margin="0,0,12,0"/>

                        <ToggleButton x:Name="WordWrapToggleButton"
                                      Grid.Column="4"
                                      Content="↩"
                                      Style="{DynamicResource DarkToggleButtonStyle}"
                                      IsChecked="True"
                                      Click="WordWrapToggleButton_Click"
                                      ToolTip="切换自动换行"
                                      Width="28" Height="22"
                                      Padding="0"
                                      FontSize="12"/>

                        <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,6,0">
                            <Button x:Name="StatusZoomOutButton"
                                    Content="−"
                                    Style="{DynamicResource DarkButtonStyle}"
                                    Click="ZoomOutButton_Click"
                                    ToolTip="缩小"
                                    Width="24" Height="22"
                                    Padding="0"
                                    FontSize="12"/>
                            <TextBlock x:Name="ZoomRatioLabel"
                                       Text="100%"
                                       Foreground="{DynamicResource TextSecondary}"
                                       FontSize="11"
                                       VerticalAlignment="Center"
                                       Margin="4,0"/>
                            <Button x:Name="StatusZoomInButton"
                                    Content="+"
                                    Style="{DynamicResource DarkButtonStyle}"
                                    Click="ZoomInButton_Click"
                                    ToolTip="放大"
                                    Width="24" Height="22"
                                    Padding="0"
                                    FontSize="12"/>
                        </StackPanel>

                        <TextBlock x:Name="EncodingLabel"
                                   Grid.Column="7"
                                   Text="UTF-8"
                                   Foreground="{DynamicResource TextSecondary}"
                                   FontSize="11"
                                   VerticalAlignment="Center"
                                   Margin="0,0,0,0"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
