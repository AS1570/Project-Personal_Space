<UserControl x:Class="WpfApp3.UserControl6"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WpfApp3"
             mc:Ignorable="d"
             d:DesignHeight="1080" d:DesignWidth="1920"
             Background="{DynamicResource BgDark}">
    <UserControl.Resources>
        <Style TargetType="ComboBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Background" Value="{DynamicResource BgSurface}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                Padding="10,6">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource BgHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="SettingComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource BgSurface}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Width" Value="220"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="IsEditable" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <Grid>
                                    <ContentPresenter x:Name="ContentSite"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                      Margin="10,0,30,0"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      TextBlock.Foreground="{DynamicResource TextPrimary}"/>
                                    <TextBlock x:Name="Arrow"
                                               Text="▼"
                                               FontSize="10"
                                               Foreground="{DynamicResource TextMuted}"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               Margin="0,0,10,0"/>
                                </Grid>
                            </ToggleButton>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border x:Name="DropDownBorder"
                                        Background="{DynamicResource BgSurface}"
                                        BorderBrush="{DynamicResource BorderColor}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Margin="0,4,0,0"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        MinWidth="{TemplateBinding ActualWidth}">
                                    <ScrollViewer>
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border Background="Transparent" Padding="0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border x:Name="checkBorder"
                                        Width="18" Height="18"
                                        Background="{DynamicResource BgSurface}"
                                        BorderBrush="{DynamicResource BorderColor}"
                                        BorderThickness="1.5"
                                        CornerRadius="4"
                                        Margin="0,0,10,0">
                                    <TextBlock x:Name="checkMark"
                                               Text="✓"
                                               FontSize="12"
                                               Foreground="{DynamicResource Accent}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Visibility="Hidden"/>
                                </Border>
                                <ContentPresenter Grid.Column="1"
                                                  VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="checkMark" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="checkBorder" Property="Background" Value="#257C8AFF"/>
                                <Setter TargetName="checkBorder" Property="BorderBrush" Value="{DynamicResource Accent}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="checkBorder" Property="Background" Value="#152D2D44"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionDivider" TargetType="Border">
            <Setter Property="Height" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource BorderColor}"/>
            <Setter Property="Margin" Value="0,8,0,16"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid MaxWidth="800" Margin="40,30,40,30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel>

                <TextBlock Text="⚙ 设置"
                           Foreground="{DynamicResource TextPrimary}"
                           FontSize="26"
                           FontWeight="Bold"
                           Margin="0,0,0,30"/>

                <!-- 主题设置 -->
                <TextBlock Text="🎨 主题设置" Style="{DynamicResource SectionTitle}"/>
                <Border Background="{DynamicResource BgPanel}"
                        CornerRadius="10"
                        Padding="20,16"
                        Margin="0,0,0,8">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="主题模式" Style="{DynamicResource LabelText}"/>
                            <ComboBox x:Name="CmbThemeMode" Style="{DynamicResource SettingComboBox}" Grid.Column="1" HorizontalAlignment="Left"/>
                        </Grid>

                        <StackPanel x:Name="PanelManualTheme" Margin="0,0,0,12">
                            <TextBlock Text="深浅色选择" Style="{DynamicResource LabelText}" Margin="0,0,0,8"/>
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="BtnThemeLight"
                                        Content="☀ 浅色"
                                        Width="100" Height="34"
                                        FontSize="13" Cursor="Hand"
                                        BorderThickness="1"
                                        Click="OnThemeVariantClick"
                                        Tag="Light">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="{DynamicResource BgSurface}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button x:Name="BtnThemeDark"
                                        Content="🌙 深色"
                                        Width="100" Height="34"
                                        FontSize="13" Cursor="Hand"
                                        BorderThickness="1"
                                        Margin="8,0,0,0"
                                        Click="OnThemeVariantClick"
                                        Tag="Dark">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="{DynamicResource BgSurface}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel x:Name="PanelAutoTheme" Visibility="Collapsed" Margin="0,0,0,12">
                            <TextBlock Text="时间段设置" Style="{DynamicResource LabelText}" Margin="0,0,0,8"/>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="浅色开始时间" Style="{DynamicResource LabelText}"/>
                                <TextBox x:Name="TxtThemeLightStartTime"
                                         Grid.Column="1"
                                         Text="06:00"
                                         Background="{DynamicResource BgSurface}"
                                         Foreground="{DynamicResource TextPrimary}"
                                         BorderBrush="{DynamicResource BorderColor}"
                                         BorderThickness="1"
                                         Height="34" Width="120"
                                         FontSize="13"
                                         Padding="10,0"
                                         HorizontalAlignment="Left"
                                         VerticalContentAlignment="Center"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="深色开始时间" Style="{DynamicResource LabelText}"/>
                                <TextBox x:Name="TxtThemeDarkStartTime"
                                         Grid.Column="1"
                                         Text="18:00"
                                         Background="{DynamicResource BgSurface}"
                                         Foreground="{DynamicResource TextPrimary}"
                                         BorderBrush="{DynamicResource BorderColor}"
                                         BorderThickness="1"
                                         Height="34" Width="120"
                                         FontSize="13"
                                         Padding="10,0"
                                         HorizontalAlignment="Left"
                                         VerticalContentAlignment="Center"/>
                            </Grid>
                        </StackPanel>

                        <TextBlock Text="当前生效模式: " Foreground="{DynamicResource TextMuted}" FontSize="12" Margin="0,4,0,8">
                            <Run Text="🌙 深色" x:Name="RunCurrentThemeLabel"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- 主题色设置 -->
                <TextBlock Text="🎯 主题色设置" Style="{DynamicResource SectionTitle}" Margin="0,20,0,12"/>
                <Border Background="{DynamicResource BgPanel}"
                        CornerRadius="10"
                        Padding="20,16"
                        Margin="0,0,0,8">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="主题色" Style="{DynamicResource LabelText}"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Border Width="34" Height="34" CornerRadius="6" Margin="0,0,8,0" VerticalAlignment="Center">
                                    <Border.Background>
                                        <SolidColorBrush x:Name="AccentColorPreview" Color="#7C8AFF"/>
                                    </Border.Background>
                                </Border>
                                <TextBox x:Name="TxtAccentColor"
                                         Background="{DynamicResource BgSurface}"
                                         Foreground="{DynamicResource TextPrimary}"
                                         BorderBrush="{DynamicResource BorderColor}"
                                         BorderThickness="1"
                                         Height="34" Width="120"
                                         FontSize="13"
                                         Padding="10,0"
                                         VerticalContentAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="预设主题色" Style="{DynamicResource LabelText}" Margin="0,0,0,8"/>
                        <WrapPanel x:Name="WrapAccentPresets" Margin="20,0,0,0"/>
                    </StackPanel>
                </Border>

                <Border Style="{DynamicResource SectionDivider}" Margin="0,20,0,24"/>

                <!-- 顶部栏调整 -->
                <TextBlock Text="📌 顶部栏调整" Style="{DynamicResource SectionTitle}"/>
                <Border Background="{DynamicResource BgPanel}"
                        CornerRadius="10"
                        Padding="20,16"
                        Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="顶部栏模式" Style="{DynamicResource LabelText}"/>
                        <ComboBox x:Name="CmbTopBarMode" Style="{DynamicResource SettingComboBox}" Grid.Column="1" HorizontalAlignment="Left"/>
                    </Grid>
                </Border>

                <!-- 顶部栏个性化选项 -->
                <TextBlock Text="🎨 顶部栏个性化选项" Style="{DynamicResource SectionTitle}" Margin="0,20,0,12"/>
                <Border Background="{DynamicResource BgPanel}"
                        CornerRadius="10"
                        Padding="20,16"
                        Margin="0,0,0,8">
                    <StackPanel>
                        <CheckBox x:Name="ChkTopBarShowTime"
                                  Style="{DynamicResource SettingCheckBox}"
                                  Content="左侧显示时间"
                                  Margin="0,0,0,10"/>
                        <CheckBox x:Name="ChkTopBarShowDate"
                                  Style="{DynamicResource SettingCheckBox}"
                                  Content="左侧显示日期"
                                  Margin="0,0,0,10"/>
                        <CheckBox x:Name="ChkTopBarShowLockButton"
                                  Style="{DynamicResource SettingCheckBox}"
                                  Content="左侧额外锁屏按钮"/>
                    </StackPanel>
                </Border>

                <!-- 顶部栏时间样式 -->
                <TextBlock Text="🕐 顶部栏时间样式" Style="{DynamicResource SectionTitle}" Margin="0,20,0,12"/>
                <Border Background="{DynamicResource BgPanel}"
                        CornerRadius="10"
                        Padding="20,16"
                        Margin="0,0,0,8">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="小时制" Style="{DynamicResource LabelText}"/>
                            <ComboBox x:Name="CmbTopBarTimeFormat" Style="{DynamicResource SettingComboBox}" Grid.Column="1" HorizontalAlignment="Left"/>
                        </Grid>
                        <CheckBox x:Name="ChkTopBarTimeShowSeconds"
                                  Style="{DynamicResource SettingCheckBox}"
                                  Content="显示秒"/>
                    </StackPanel>
                </Border>

                <!-- 顶部栏日期样式 -->
                <TextBlock Text="📅 顶部栏日期样式" Style="{DynamicResource SectionTitle}" Margin="0,20,0,12"/>
                <Border Background="{DynamicResource BgPanel}"
                        CornerRadius="10"
                        Padding="20,16"
                        Margin="0,0,0,8">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="排布逻辑" Style="{DynamicResource LabelText}"/>
                            <ComboBox x:Name="CmbTopBarDateOrder" Style="{DynamicResource SettingComboBox}" Grid.Column="1" HorizontalAlignment="Left"/>
                        </Grid>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="日期样式" Style="{DynamicResource LabelText}"/>
                            <ComboBox x:Name="CmbTopBarDateStyle" Style="{DynamicResource SettingComboBox}" Grid.Column="1" HorizontalAlignment="Left"/>
                        </Grid>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="月份样式" Style="{DynamicResource LabelText}"/>
                            <ComboBox x:Name="CmbTopBarMonthStyle" Style="{DynamicResource SettingComboBox}" Grid.Column="1" HorizontalAlignment="Left"/>
                        </Grid>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="年份样式" Style="{DynamicResource LabelText}"/>
                            <ComboBox x:Name="CmbTopBarYearStyle" Style="{DynamicResource SettingComboBox}" Grid.Column="1" HorizontalAlignment="Left"/>
                        </Grid>
                        <CheckBox x:Name="ChkTopBarShowDayOfWeek"
                                  Style="{DynamicResource SettingCheckBox}"
                                  Content="显示星期"
                                  Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="星期显示位置" Style="{DynamicResource LabelText}"/>
                            <ComboBox x:Name="CmbTopBarDayOfWeekPosition" Style="{DynamicResource SettingComboBox}" Grid.Column="1" HorizontalAlignment="Left"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{DynamicResource SectionDivider}" Margin="0,20,0,24"/>

                <!-- 底部栏调整 -->
                <TextBlock Text="📌 底部栏调整" Style="{DynamicResource SectionTitle}" Margin="0,20,0,12"/>
                <Border Background="{DynamicResource BgPanel}"
                        CornerRadius="10"
                        Padding="20,16"
                        Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="底部栏模式" Style="{DynamicResource LabelText}"/>
                        <ComboBox x:Name="CmbBottomBarAdjustMode" Style="{DynamicResource SettingComboBox}" Grid.Column="1" HorizontalAlignment="Left"/>
                    </Grid>
                </Border>

                <!-- 底部栏排布个性化选项 -->
                <TextBlock Text="📐 底部栏排布个性化选项" Style="{DynamicResource SectionTitle}"/>
                <Border Background="{DynamicResource BgPanel}"
                        CornerRadius="10"
                        Padding="20,16"
                        Margin="0,0,0,8">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="底部栏样式" Style="{DynamicResource LabelText}"/>
                            <ComboBox x:Name="CmbBottomBarStyle" Style="{DynamicResource SettingComboBox}" Grid.Column="1" HorizontalAlignment="Left"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="底部栏排版" Style="{DynamicResource LabelText}"/>
                            <ComboBox x:Name="CmbBottomBarLayout" Style="{DynamicResource SettingComboBox}" Grid.Column="1" HorizontalAlignment="Left"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 底部栏按钮选项 -->
                <TextBlock Text="🔘 底部栏按钮选项" Style="{DynamicResource SectionTitle}" Margin="0,20,0,12"/>
                <Border Background="{DynamicResource BgPanel}"
                        CornerRadius="10"
                        Padding="20,16"
                        Margin="0,0,0,8">
                    <StackPanel>
                        <CheckBox x:Name="ChkButton8ShowSongName"
                                  Style="{DynamicResource SettingCheckBox}"
                                  Content="底部栏显示当前歌曲名称"
                                  Margin="0,0,0,10"/>
                        <CheckBox x:Name="ChkButton8Show"
                                  Style="{DynamicResource SettingCheckBox}"
                                  Content="显示音频控制器"
                                  Margin="0,0,0,10"/>
                        <CheckBox x:Name="ChkButton9Show"
                                  Style="{DynamicResource SettingCheckBox}"
                                  Content="显示日期/时间"
                                  Margin="0,0,0,10"/>
                        <CheckBox x:Name="ChkButton10Show"
                                  Style="{DynamicResource SettingCheckBox}"
                                  Content="启用显示桌面快捷键"/>
                    </StackPanel>
                </Border>

                <!-- 底部栏日期时间样式 -->
                <TextBlock Text="🕐 底部栏日期时间样式" Style="{DynamicResource SectionTitle}" Margin="0,20,0,12"/>
                <Border Background="{DynamicResource BgPanel}"
                        CornerRadius="10"
                        Padding="20,16"
                        Margin="0,0,0,20">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="日期时间排版" Style="{DynamicResource LabelText}"/>
                            <ComboBox x:Name="CmbButton9Alignment" Style="{DynamicResource SettingComboBox}" Grid.Column="1" HorizontalAlignment="Left"/>
                        </Grid>

                        <CheckBox x:Name="ChkButton9ShowTime"
                                  Style="{DynamicResource SettingCheckBox}"
                                  Content="显示时间"
                                  Margin="0,0,0,10"/>
                        <Border Background="{DynamicResource BgSurface}"
                                CornerRadius="8"
                                Padding="14,12"
                                Margin="20,0,0,14">
                            <StackPanel>
                                <TextBlock Text="▶ 时间样式" Foreground="{DynamicResource TextSecondary}" FontSize="13" Margin="0,0,0,8"/>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="小时制" Style="{DynamicResource LabelText}"/>
                                    <ComboBox x:Name="CmbButton9TimeFormat" Style="{DynamicResource SettingComboBox}" Grid.Column="1" HorizontalAlignment="Left"/>
                                </Grid>
                                <CheckBox x:Name="ChkButton9TimeShowSeconds"
                                          Style="{DynamicResource SettingCheckBox}"
                                          Content="显示秒"/>
                            </StackPanel>
                        </Border>

                        <CheckBox x:Name="ChkButton9ShowDate"
                                  Style="{DynamicResource SettingCheckBox}"
                                  Content="显示日期"
                                  Margin="0,0,0,10"/>
                        <Border Background="{DynamicResource BgSurface}"
                                CornerRadius="8"
                                Padding="14,12"
                                Margin="20,0,0,0">
                            <StackPanel>
                                <TextBlock Text="▶ 日期样式" Foreground="{DynamicResource TextSecondary}" FontSize="13" Margin="0,0,0,8"/>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="排布逻辑" Style="{DynamicResource LabelText}"/>
                                    <ComboBox x:Name="CmbButton9DateOrder" Style="{DynamicResource SettingComboBox}" Grid.Column="1" HorizontalAlignment="Left"/>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="日期样式" Style="{DynamicResource LabelText}"/>
                                    <ComboBox x:Name="CmbButton9DateStyle" Style="{DynamicResource SettingComboBox}" Grid.Column="1" HorizontalAlignment="Left"/>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="月份样式" Style="{DynamicResource LabelText}"/>
                                    <ComboBox x:Name="CmbButton9MonthStyle" Style="{DynamicResource SettingComboBox}" Grid.Column="1" HorizontalAlignment="Left"/>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="年份样式" Style="{DynamicResource LabelText}"/>
                                    <ComboBox x:Name="CmbButton9YearStyle" Style="{DynamicResource SettingComboBox}" Grid.Column="1" HorizontalAlignment="Left"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Style="{DynamicResource SectionDivider}" Margin="0,20,0,24"/>

                <!-- 音频快速选择 -->
                <TextBlock Text="🎵 音频快速选择" Style="{DynamicResource SectionTitle}" Margin="0,20,0,12"/>
                <Border Background="{DynamicResource BgPanel}"
                        CornerRadius="10"
                        Padding="20,16"
                        Margin="0,0,0,20">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="音频文件" Style="{DynamicResource LabelText}"/>
                            <TextBox x:Name="TxtAudioQuickSelectPath"
                                     Grid.Column="1"
                                     Background="{DynamicResource BgSurface}"
                                     Foreground="{DynamicResource TextPrimary}"
                                     BorderBrush="{DynamicResource BorderColor}"
                                     BorderThickness="1"
                                     Height="34"
                                     FontSize="13"
                                     Padding="10,0"
                                     IsReadOnly="True"
                                     VerticalContentAlignment="Center"/>
                            <Button x:Name="BtnAudioQuickSelectBrowse"
                                    Grid.Column="2"
                                    Content="选择音频"
                                    Width="90" Height="34"
                                    Background="{DynamicResource Accent}"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    FontSize="12"
