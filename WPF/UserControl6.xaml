                                Margin="0,10,0,0"
                                Click="BtnSavePasswordHint_Click"/>
                    </StackPanel>
                </Border>

                <Border Style="{DynamicResource SectionDivider}" Margin="0,20,0,24"/>

                <!-- 文件夹管理 -->
                <TextBlock Text="📁 文件夹管理" Style="{DynamicResource SectionTitle}" Margin="0,20,0,12"/>
                <Border Background="{DynamicResource BgPanel}"
                        CornerRadius="10"
                        Padding="20,16"
                        Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="当前文件夹地址" Foreground="{DynamicResource TextMuted}" FontSize="12" Margin="0,0,0,4"/>
                        <TextBlock x:Name="TxtCurrentFolderPath"
                                   Foreground="{DynamicResource TextPrimary}"
                                   FontSize="13"
                                   Margin="0,0,0,12"
                                   TextTrimming="CharacterEllipsis"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtNewFolderPath"
                                     Background="{DynamicResource BgSurface}"
                                     Foreground="{DynamicResource TextPrimary}"
                                     BorderBrush="{DynamicResource BorderColor}"
                                     BorderThickness="1"
                                     Height="34"
                                     FontSize="13"
                                     Padding="10,0"
                                     VerticalContentAlignment="Center"/>
                            <Button x:Name="BtnFolderPreview"
                                    Grid.Column="1"
                                    Content="选择文件夹"
                                    Width="80" Height="34"
                                    Background="{DynamicResource BgHover}"
                                    Foreground="{DynamicResource TextPrimary}"
                                    BorderBrush="{DynamicResource BorderColor}"
                                    BorderThickness="1"
                                    Cursor="Hand"
                                    FontSize="12"
                                    Margin="8,0,0,0"
                                    Click="BtnFolderPreview_Click"/>
                        </Grid>
                        <Button x:Name="BtnChangeFolder"
                                Content="更换文件夹"
                                Width="150" Height="34"
                                Background="{DynamicResource Accent}"
                                Foreground="White"
                                BorderThickness="0"
                                Cursor="Hand"
                                FontSize="13"
                                Margin="0,0,0,12"
                                Click="BtnChangeFolder_Click"/>
                        <TextBlock Text="⚠ 提示：更换文件夹可能导致部分设置（如音频快速选择路径）失效"
                                   Foreground="{DynamicResource TextMuted}"
                                   FontSize="11"
                                   Margin="0,0,0,4"
                                   TextWrapping="Wrap"/>
                        <TextBlock x:Name="TxtDefaultFolderHint"
                                   Foreground="{DynamicResource TextMuted}"
                                   FontSize="11"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Border Style="{DynamicResource SectionDivider}" Margin="0,20,0,24"/>

                <TextBlock Text="🎭 软件伪装" Style="{DynamicResource SectionTitle}" Margin="0,20,0,12"/>
                <Border Background="{DynamicResource BgPanel}"
                        CornerRadius="10"
                        Padding="20,16"
                        Margin="0,0,0,8">
                    <StackPanel>
                        <CheckBox x:Name="ChkDisguiseEnabled"
                                  Style="{DynamicResource SettingCheckBox}"
                                  Content="启用软件伪装"
                                  Margin="0,0,0,10"/>

                        <Border x:Name="PanelDisguiseSettings"
                                Background="{DynamicResource BgSurface}"
                                CornerRadius="8"
                                Padding="14,12"
                                Margin="20,0,0,0">
                            <StackPanel>
                                <TextBlock Text="伪装选项" Foreground="{DynamicResource TextSecondary}" FontSize="13" FontWeight="Bold" Margin="0,0,0,10"/>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="伪装名称" Style="{DynamicResource LabelText}"/>
                                    <TextBox x:Name="TxtDisguiseAppName"
                                             Grid.Column="1"
                                             Background="{DynamicResource BgSurface}"
                                             Foreground="{DynamicResource TextPrimary}"
                                             BorderBrush="{DynamicResource BorderColor}"
                                             BorderThickness="1"
                                             Height="34" Width="300"
                                             FontSize="13"
                                             Padding="10,0"
                                             VerticalContentAlignment="Center"
                                             HorizontalAlignment="Left"/>
                                </Grid>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="伪装图标" Style="{DynamicResource LabelText}"/>
                                    <TextBox x:Name="TxtDisguiseIconPath"
                                             Grid.Column="1"
                                             Background="{DynamicResource BgSurface}"
                                             Foreground="{DynamicResource TextPrimary}"
                                             BorderBrush="{DynamicResource BorderColor}"
                                             BorderThickness="1"
                                             Height="34"
                                             FontSize="13"
                                             Padding="10,0"
                                             IsReadOnly="True"
                                             VerticalContentAlignment="Center"/>
                                    <Button x:Name="BtnDisguiseIconBrowse"
                                            Grid.Column="2"
                                            Content="选择图标"
                                            Width="90" Height="34"
                                            Background="{DynamicResource Accent}"
                                            Foreground="White"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            FontSize="12"
                                            Margin="8,0,0,0"
                                            Click="BtnDisguiseIconBrowse_Click"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Button x:Name="BtnDisguiseRestoreDefault"
                                Content="恢复默认"
                                Width="110" Height="34"
                                Background="{DynamicResource BgHover}"
                                Foreground="{DynamicResource TextPrimary}"
                                BorderBrush="{DynamicResource BorderColor}"
                                BorderThickness="1"
                                Cursor="Hand"
                                FontSize="13"
                                HorizontalAlignment="Left"
                                Margin="0,12,0,0"
                                Click="BtnDisguiseRestoreDefault_Click"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
