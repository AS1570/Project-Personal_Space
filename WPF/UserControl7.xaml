<UserControl x:Class="WpfApp3.UserControl7"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WpfApp3"
             mc:Ignorable="d"
             d:DesignHeight="1080" d:DesignWidth="1920"
             Focusable="True">
    <UserControl.Resources>
        <local:FileSizeFormatConverter x:Key="FileSizeConverter"/>
        <local:DateTimeFormatConverter x:Key="DateTimeConverter"/>

        <Style x:Key="DarkButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource BgSurface}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource BgHover}"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource Accent}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource BgHoverAlt}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource BgHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource BgSurface}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CaretBrush" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource Accent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource BgSurface}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="6"
                                                Padding="8,4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="16"/>
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0"
                                                                  VerticalAlignment="Center"
                                                                  Content="{TemplateBinding Content}"
                                                                  ContentTemplate="{TemplateBinding ContentTemplate}"/>
                                                <Path Grid.Column="1"
                                                      Data="M0,0 L4,4 L8,0"
                                                      Fill="{DynamicResource TextSecondary}"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Stroke="{DynamicResource TextSecondary}"
                                                      StrokeThickness="1"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   PopupAnimation="Slide"
                                   AllowsTransparency="True">
                                <Border Background="{DynamicResource BgSurface}"
                                        BorderBrush="{DynamicResource BorderColor}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Margin="0,2,0,0">
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkRadioButton" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border"
                                Background="Transparent"
                                CornerRadius="6"
                                Padding="10,6">
                            <StackPanel Orientation="Horizontal">
                                <Grid Width="16" Height="16" Margin="0,0,8,0">
                                    <Ellipse x:Name="outer"
                                             Width="16" Height="16"
                                             Stroke="{DynamicResource TextMuted}"
                                             StrokeThickness="1.5"
                                             Fill="Transparent"/>
                                    <Ellipse x:Name="inner"
                                             Width="8" Height="8"
                                             Fill="Transparent"/>
                                </Grid>
                                <TextBlock Text="{TemplateBinding Content}"
                                           VerticalAlignment="Center"
                                           Foreground="{TemplateBinding Foreground}"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="outer" Property="Stroke" Value="{DynamicResource Accent}"/>
                                <Setter TargetName="inner" Property="Fill" Value="{DynamicResource Accent}"/>
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource AccentBg08}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource BgHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource DarkButton}">
            <Setter Property="BorderBrush" Value="{DynamicResource DangerBorder}"/>
            <Setter Property="Foreground" Value="{DynamicResource Danger}"/>
        </Style>

        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource DarkButton}">
            <Setter Property="Background" Value="{DynamicResource Accent}"/>
            <Setter Property="Foreground" Value="{DynamicResource White}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Accent}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource AccentLight}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource AccentDark}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ListViewItemStyle" TargetType="ListViewItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4,1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="4"
                                Margin="2,1">
                            <GridViewRowPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource BgHover}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource AccentBg10}"/>
                                <Setter Property="Foreground" Value="{DynamicResource AccentLight}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkGridViewColumnHeader" TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="{DynamicResource BgPanel}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridViewColumnHeader">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkToggleButton" TargetType="ToggleButton">
            <Setter Property="Background" Value="{DynamicResource BgSurface}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource BgHover}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource Accent}"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource AccentLight}"/>
                                <Setter Property="Foreground" Value="{DynamicResource White}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource BgDark}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource BgPanel}"
                BorderBrush="{DynamicResource BorderColor}"
                BorderThickness="0,0,0,1"
                Padding="10,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="BtnToggleLeftPanel"
                        Grid.Column="0"
                        Style="{DynamicResource IconButtonStyle}"
                        Click="BtnToggleLeftPanel_Click"
                        ToolTip="隐藏/显示左侧面板">
                    <TextBlock x:Name="ToggleLeftIcon" Text="◀" FontSize="13"/>
                </Button>

                <Button x:Name="BtnRefresh"
                        Grid.Column="1"
                        Style="{DynamicResource IconButtonStyle}"
                        Click="BtnRefresh_Click"
                        ToolTip="刷新文件列表"
                        Margin="4,0,0,0">
                    <TextBlock Text="🔄" FontSize="16"/>
                </Button>

                <Button x:Name="BtnOpenExplorer"
                        Grid.Column="2"
                        Style="{DynamicResource IconButtonStyle}"
                        Click="BtnOpenExplorer_Click"
                        Margin="4,0,0,0"
                        ToolTip="在资源管理器中打开">
                    <TextBlock Text="📂" FontSize="16"/>
                </Button>

                <TextBox x:Name="SearchTextBox"
                         Grid.Column="3"
                         Height="34"
                         Style="{DynamicResource DarkTextBox}"
                         TextChanged="SearchTextBox_TextChanged"
                         Margin="8,0,8,0">
                    <TextBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>

                <Button x:Name="BtnImport"
                        Grid.Column="4"
                        Style="{DynamicResource AccentButton}"
                        Click="BtnImport_Click"
                        ToolTip="导入文件">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📥" FontSize="14" Margin="0,0,6,0"/>
                        <TextBlock Text="导入" FontSize="13"/>
                    </StackPanel>
                </Button>

                <Button x:Name="BtnToggleRightPanel"
                        Grid.Column="5"
                        Style="{DynamicResource IconButtonStyle}"
                        Click="BtnToggleRightPanel_Click"
                        Margin="8,0,0,0"
                        ToolTip="隐藏/显示右侧面板">
                    <TextBlock x:Name="ToggleRightIcon" Text="▶" FontSize="13"/>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="LeftColumn" Width="220"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition x:Name="FileColumn" Width="*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition x:Name="RightColumn" Width="260"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{DynamicResource BgPanel}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="12,12,12,4">
                        <TextBlock Text="文件类型筛选"
                                   Foreground="{DynamicResource TextSecondary}"
                                   FontSize="11"
                                   Margin="0,0,0,8"/>

                        <RadioButton x:Name="FilterAll"
                                     Content="全部文件"
                                     Style="{DynamicResource DarkRadioButton}"
                                     IsChecked="True"
                                     Checked="FilterRadioButton_Checked"
                                     Tag="all"/>

                        <RadioButton x:Name="FilterImage"
                                     Content="图片"
                                     Style="{DynamicResource DarkRadioButton}"
                                     Checked="FilterRadioButton_Checked"
                                     Tag="image"/>

                        <RadioButton x:Name="FilterVideo"
                                     Content="视频"
                                     Style="{DynamicResource DarkRadioButton}"
                                     Checked="FilterRadioButton_Checked"
                                     Tag="video"/>

                        <RadioButton x:Name="FilterMusic"
                                     Content="音乐"
                                     Style="{DynamicResource DarkRadioButton}"
                                     Checked="FilterRadioButton_Checked"
                                     Tag="music"/>

                        <RadioButton x:Name="FilterText"
                                     Content="文本文件"
                                     Style="{DynamicResource DarkRadioButton}"
                                     Checked="FilterRadioButton_Checked"
                                     Tag="text"/>

                        <RadioButton x:Name="FilterOther"
                                     Content="其他"
                                     Style="{DynamicResource DarkRadioButton}"
                                     Checked="FilterRadioButton_Checked"
                                     Tag="other"/>
                    </StackPanel>

                    <Border Grid.Row="1"
                            Background="{DynamicResource BgDark}"
                            CornerRadius="8"
                            Margin="8,4,8,12"
                            Padding="10">
                        <StackPanel>
                            <TextBlock Text="📊 文件统计"
                                       Foreground="{DynamicResource TextSecondary}"
                                       FontSize="12"
                                       FontWeight="Bold"
                                       Margin="0,0,0,8"/>

                            <StackPanel x:Name="StatsPanel">
                                <TextBlock x:Name="StatAll"
                                           Text="全部: 0"
                                           Foreground="{DynamicResource TextSecondary}"
                                           FontSize="11"
                                           Margin="0,1"/>
                                <TextBlock x:Name="StatImage"
                                           Text="图片: 0"
                                           Foreground="{DynamicResource TextSecondary}"
                                           FontSize="11"
                                           Margin="0,1"/>
                                <TextBlock x:Name="StatVideo"
                                           Text="视频: 0"
                                           Foreground="{DynamicResource TextSecondary}"
                                           FontSize="11"
                                           Margin="0,1"/>
                                <TextBlock x:Name="StatMusic"
                                           Text="音乐: 0"
                                           Foreground="{DynamicResource TextSecondary}"
                                           FontSize="11"
                                           Margin="0,1"/>
                                <TextBlock x:Name="StatText"
                                           Text="文本: 0"
                                           Foreground="{DynamicResource TextSecondary}"
                                           FontSize="11"
                                           Margin="0,1"/>
                                <TextBlock x:Name="StatOther"
                                           Text="其他: 0"
                                           Foreground="{DynamicResource TextSecondary}"
                                           FontSize="11"
                                           Margin="0,1"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="5"
                          HorizontalAlignment="Stretch"
                          Background="Transparent"
                          ResizeBehavior="PreviousAndNext"
                          ResizeDirection="Columns"/>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{DynamicResource BgSurface}"
                        BorderBrush="{DynamicResource BorderColor}"
                        BorderThickness="0,0,0,1"
                        Padding="8,5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="BtnSortToggle"
                                Grid.Column="0"
                                Style="{DynamicResource DarkButton}"
                                Width="100"
                                Height="30"
                                Click="BtnSortToggle_Click"
                                ToolTip="选择排序方式"
                                Padding="8,4">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="SortTypeLabel" Text="名称" FontSize="12"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text=" ▾" FontSize="9"
                                           Foreground="{DynamicResource TextMuted}"
                                           VerticalAlignment="Center" Margin="4,0,0,0"/>
                            </StackPanel>
                        </Button>

                        <Popup x:Name="SortPopup"
                               PlacementTarget="{Binding ElementName=BtnSortToggle}"
                               Placement="Bottom"
                               StaysOpen="False"
                               AllowsTransparency="True">
                            <Border Background="{DynamicResource BgSurface}"
                                    BorderBrush="{DynamicResource BorderColor}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    MinWidth="100"
                                    Margin="0,2,0,0">
                                <StackPanel>
                                    <RadioButton x:Name="SortName"
                                                 Content="名称"
                                                 Style="{DynamicResource DarkRadioButton}"
                                                 Checked="SortRadioButton_Checked"
                                                 Tag="name"/>
                                    <RadioButton x:Name="SortTime"
                                                 Content="时间"
                                                 Style="{DynamicResource DarkRadioButton}"
                                                 Checked="SortRadioButton_Checked"
                                                 Tag="time"/>
                                    <RadioButton x:Name="SortType"
                                                 Content="类型"
                                                 Style="{DynamicResource DarkRadioButton}"
                                                 Checked="SortRadioButton_Checked"
                                                 Tag="type"/>
                                    <RadioButton x:Name="SortSize"
                                                 Content="大小"
                                                 Style="{DynamicResource DarkRadioButton}"
                                                 Checked="SortRadioButton_Checked"
                                                 Tag="size"/>
                                </StackPanel>
                            </Border>
                        </Popup>

                        <Button x:Name="BtnSortOrder"
                                Grid.Column="1"
                                Style="{DynamicResource IconButtonStyle}"
                                Click="BtnSortOrder_Click"
                                Margin="4,0,0,0"
                                ToolTip="切换顺序/倒序">
                            <TextBlock x:Name="SortOrderIcon" Text="↑" FontSize="14"/>
                        </Button>

                        <Button Grid.Column="2"
                                Style="{DynamicResource IconButtonStyle}"
                                Click="ViewToggle_Click"
                                Margin="12,0,0,0"
                                ToolTip="切换列表/图标视图">
                            <TextBlock x:Name="ViewToggleIcon" Text="☰" FontSize="16"/>
                        </Button>

                        <TextBlock x:Name="FileCountLabel"
                                   Grid.Column="4"
                                   Text="共 0 个文件"
                                   Foreground="{DynamicResource TextMuted}"
                                   FontSize="12"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <ListView x:Name="FileListView"
                          Grid.Row="1"
                          Background="Transparent"
                          Foreground="{DynamicResource TextPrimary}"
                          BorderThickness="0"
                          SelectionChanged="FileListView_SelectionChanged"
                          MouseDoubleClick="FileListView_MouseDoubleClick"
                          ItemContainerStyle="{DynamicResource ListViewItemStyle}">
                    <ListView.View>
                        <GridView ColumnHeaderContainerStyle="{DynamicResource DarkGridViewColumnHeader}">
                            <GridViewColumn Header="文件名" Width="280">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding FileName}"
                                                       Foreground="{DynamicResource TextPrimary}"
                                                       FontSize="13"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="扩展名" Width="100">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Extension}"
                                                   Foreground="{DynamicResource Accent}"
                                                   FontSize="12"
                                                   VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="大小" Width="120">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding FileSize, Converter={StaticResource FileSizeConverter}}"
                                                   Foreground="{DynamicResource TextSecondary}"
                                                   FontSize="12"
                                                   VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="保存时间" Width="180">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding SaveTime, Converter={StaticResource DateTimeConverter}}"
                                                   Foreground="{DynamicResource TextSecondary}"
                                                   FontSize="12"
                                                   VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>

                <ScrollViewer x:Name="TileScrollViewer"
                              Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Visibility="Collapsed">
                    <WrapPanel x:Name="TileWrapPanel" Margin="8"/>
                </ScrollViewer>
            </Grid>

            <GridSplitter Grid.Column="3"
                          Width="5"
                          HorizontalAlignment="Stretch"
                          Background="Transparent"
                          ResizeBehavior="PreviousAndNext"
                          ResizeDirection="Columns"/>

            <Border Grid.Column="4"
                    Background="{DynamicResource BgPanel}"
                    Padding="12">
                <StackPanel>
                    <TextBlock Text="📋 文件属性"
                               Foreground="{DynamicResource TextPrimary}"
                               FontSize="14"
                               FontWeight="Bold"
                               Margin="0,0,0,12"/>

                    <TextBlock Text="文件名称"
                               Foreground="{DynamicResource TextMuted}"
                               FontSize="11"
                               Margin="0,0,0,4"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="FileNameTextBox"
                                 Grid.Column="0"
                                 Style="{DynamicResource DarkTextBox}"
                                 FontSize="12"
                                 TextChanged="FileNameTextBox_TextChanged"/>
                        <Button x:Name="BtnRename"
                                Grid.Column="1"
                                Content="重命名"
                                Style="{DynamicResource DarkButton}"
                                Click="BtnRename_Click"
                                FontSize="11"
                                Padding="8,4"
                                Margin="6,0,0,0"
                                Width="60"/>
                    </Grid>

                    <TextBlock Text="扩展名"
                               Foreground="{DynamicResource TextMuted}"
                               FontSize="11"
                               Margin="0,10,0,4"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="ExtensionTextBox"
                                 Grid.Column="0"
                                 Style="{DynamicResource DarkTextBox}"
                                 FontSize="12"
                                 TextChanged="ExtensionTextBox_TextChanged"/>
                        <Button x:Name="BtnChangeExtension"
                                Grid.Column="1"
                                Content="修改"
                                Style="{DynamicResource DarkButton}"
                                Click="BtnChangeExtension_Click"
                                FontSize="11"
                                Padding="8,4"
                                Margin="6,0,0,0"
                                Width="60"/>
                    </Grid>

                    <TextBlock Text="文件大小"
                               Foreground="{DynamicResource TextMuted}"
                               FontSize="11"
                               Margin="0,10,0,4"/>
                    <TextBlock x:Name="FileSizeLabel"
                               Text="—"
                               Foreground="{DynamicResource TextPrimary}"
                               FontSize="13"
                               Margin="0,0,0,8"/>

                    <TextBlock Text="保存时间"
                               Foreground="{DynamicResource TextMuted}"
                               FontSize="11"
                               Margin="0,0,0,4"/>
                    <TextBlock x:Name="SaveTimeLabel"
                               Text="—"
                               Foreground="{DynamicResource TextPrimary}"
                               FontSize="13"
                               Margin="0,0,0,8"/>

                    <TextBlock Text="完整路径"
                               Foreground="{DynamicResource TextMuted}"
                               FontSize="11"
                               Margin="0,0,0,4"/>
                    <TextBlock x:Name="FullPathLabel"
                               Text="—"
                               Foreground="{DynamicResource TextSecondary}"
                               FontSize="11"
                               TextWrapping="Wrap"
                               Margin="0,0,0,16"/>

                    <Border Height="1"
                            Background="{DynamicResource BorderColor}"
                            Margin="0,0,0,12"/>
                    <TextBlock Text="⚡ 操作"
                               Foreground="{DynamicResource TextPrimary}"
                               FontSize="14"
                               FontWeight="Bold"
                               Margin="0,0,0,10"/>

                    <Button x:Name="BtnOpenFile"
                            Content="📂 打开文件"
                            Style="{DynamicResource AccentButton}"
                            Click="BtnOpenFile_Click"
                            Margin="0,0,0,6"
                            IsEnabled="False"/>

                    <Button x:Name="BtnExportFile"
                            Content="📤 导出文件"
                            Style="{DynamicResource DarkButton}"
                            Click="BtnExportFile_Click"
                            Margin="0,0,0,6"
                            IsEnabled="False"/>

                    <Button x:Name="BtnDeleteFile"
                            Content="🗑 删除文件"
                            Style="{DynamicResource DangerButton}"
                            Click="BtnDeleteFile_Click"
                            IsEnabled="False"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
