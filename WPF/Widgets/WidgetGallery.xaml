<UserControl x:Class="WpfApp3.Widgets.WidgetGallery"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="420">

    <Border Background="Transparent" ClipToBounds="True" CornerRadius="16">
        <Border Background="{DynamicResource BgPanel}"
                CornerRadius="16"
                Padding="24"
                BorderBrush="{DynamicResource BorderColor}"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="24" ShadowDepth="6" Opacity="0.55"/>
            </Border.Effect>
            <StackPanel>
            <TextBlock Text="添加小组件"
                       Foreground="{DynamicResource TextPrimary}"
                       FontSize="18"
                       FontWeight="Bold"
                       Margin="0,0,0,6"/>

            <TextBlock Text="选择要添加到桌面的小组件类型"
                       Foreground="{DynamicResource TextSecondary}"
                       FontSize="13"
                       Margin="0,0,0,18"/>

            <WrapPanel Margin="0,0,0,6">
                <Button x:Name="BtnClock"
                        Width="110" Height="90"
                        Margin="0,0,10,10"
                        Cursor="Hand"
                        Click="BtnClock_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd"
                                    Background="{DynamicResource BgHover}"
                                    CornerRadius="12"
                                    BorderBrush="Transparent"
                                    BorderThickness="1.5">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="🕐" FontSize="28" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                    <TextBlock Text="时钟"
                                               Foreground="{DynamicResource TextPrimary}"
                                               FontSize="13"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource Accent}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button x:Name="BtnDate"
                        Width="110" Height="90"
                        Margin="0,0,10,10"
                        Cursor="Hand"
                        Click="BtnDate_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd"
                                    Background="{DynamicResource BgHover}"
                                    CornerRadius="12"
                                    BorderBrush="Transparent"
                                    BorderThickness="1.5">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="📅" FontSize="28" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                    <TextBlock Text="日期"
                                               Foreground="{DynamicResource TextPrimary}"
                                               FontSize="13"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource Accent}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button x:Name="BtnStickyNote"
                        Width="110" Height="90"
                        Margin="0,0,10,10"
                        Cursor="Hand"
                        Click="BtnStickyNote_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd"
                                    Background="{DynamicResource BgHover}"
                                    CornerRadius="12"
                                    BorderBrush="Transparent"
                                    BorderThickness="1.5">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="📝" FontSize="28" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                    <TextBlock Text="便签"
                                               Foreground="{DynamicResource TextPrimary}"
                                               FontSize="13"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource Accent}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button x:Name="BtnQuickLaunch"
                        Width="110" Height="90"
                        Margin="0,0,10,10"
                        Cursor="Hand"
                        Click="BtnQuickLaunch_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd"
                                    Background="{DynamicResource BgHover}"
                                    CornerRadius="12"
                                    BorderBrush="Transparent"
                                    BorderThickness="1.5">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="⚡" FontSize="28" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                    <TextBlock Text="快捷启动"
                                               Foreground="{DynamicResource TextPrimary}"
                                               FontSize="13"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource Accent}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button x:Name="BtnImage"
                        Width="110" Height="90"
                        Margin="0,0,10,10"
                        Cursor="Hand"
                        Click="BtnImage_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd"
                                    Background="{DynamicResource BgHover}"
                                    CornerRadius="12"
                                    BorderBrush="Transparent"
                                    BorderThickness="1.5">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="🖼" FontSize="28" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                    <TextBlock Text="图片展示"
                                               Foreground="{DynamicResource TextPrimary}"
                                               FontSize="13"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource Accent}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button x:Name="BtnAudio"
                        Width="110" Height="90"
                        Margin="0,0,10,10"
                        Cursor="Hand"
                        Click="BtnAudio_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd"
                                    Background="{DynamicResource BgHover}"
                                    CornerRadius="12"
                                    BorderBrush="Transparent"
                                    BorderThickness="1.5">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="🎵" FontSize="28" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                    <TextBlock Text="音频控制器"
                                               Foreground="{DynamicResource TextPrimary}"
                                               FontSize="13"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource Accent}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </WrapPanel>

            <Button Content="取消"
                    Width="80" Height="32"
                    Background="Transparent"
                    Foreground="{DynamicResource TextSecondary}"
                    BorderBrush="{DynamicResource BorderColor}"
                    BorderThickness="1"
                    Cursor="Hand"
                    FontSize="12"
                    HorizontalAlignment="Right"
                    Click="BtnCancel_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource BgHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
        </Border>
    </Border>
</UserControl>
